# Discord User Token (from browser Developer Tools)
# WARNING: This is a USER token, not a bot token. Keep it secret!
DISCORD_TOKEN=your_user_token_here

# Groq API Key (from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq Backup API Key (optional - from a different Groq account for rate limit rotation)
GROQ_API_KEY_BACKUP=your_groq_backup_api_key_here
